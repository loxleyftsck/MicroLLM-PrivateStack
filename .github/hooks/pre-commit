#!/usr/bin/env python3
"""
Pre-commit secret scan hook — MicroLLM-PrivateStack
Preventive Control (2026-02-28): blocks commits containing credentials,
tokens, API keys, or known-weak JWT secrets.

Install:
    cp .github/hooks/pre-commit .git/hooks/pre-commit
    chmod +x .git/hooks/pre-commit

Or use with pre-commit framework:
    repos:
      - repo: local
        hooks:
          - id: secret-scan
            name: Secret Scan
            entry: python .github/hooks/pre-commit
            language: python
            pass_filenames: false
"""

import subprocess
import sys
import re
from pathlib import Path

# ── Patterns that indicate a secret is being committed ────────────────────────
SECRET_PATTERNS = [
    # JWT weak defaults
    (r'change[-_]?me[-_]?in[-_]?production', 'Weak JWT secret placeholder'),
    (r'dev[-_]?secret[-_]?key', 'Dev JWT secret'),
    (r'jwt[-_]?secret\s*=\s*["\'][^"\']{1,31}["\']', 'Short/weak JWT secret value'),

    # Credential files
    (r'Password:\s*\S+@\S+', 'Plaintext password in credential-style line'),
    (r'(password|passwd|pwd)\s*[:=]\s*["\'][^"\']{6,}["\']', 'Hardcoded password assignment'),

    # Bearer tokens / API keys  ── catches tokens >20 chars in common formats
    (r'Bearer\s+[A-Za-z0-9_\-]{20,}', 'Hardcoded Bearer token'),
    (r'(api[_-]?key|apikey)\s*[:=]\s*["\'][A-Za-z0-9_\-]{16,}["\']', 'Hardcoded API key'),

    # Private keys
    (r'-----BEGIN (RSA |EC )?PRIVATE KEY-----', 'Private key material'),

    # JWT tokens (eyJ... format)
    (r'eyJ[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}', 'JWT token literal'),
]

# ── Files / patterns to skip ──────────────────────────────────────────────────
SKIP_PATHS = {
    '.github/hooks/pre-commit',        # this file — contains patterns, not secrets
    'tests/stress-test-adversarial.ps1',  # contains test payloads (fake tokens)
    'backend/security/guardrails.py',  # contains detection patterns
    'backend/api_gateway.py',          # contains _KNOWN_WEAK_SECRETS blocklist
                                       # for startup validation — not actual secrets
}

SKIP_EXTENSIONS = {'.pyc', '.png', '.jpg', '.jpeg', '.gif', '.ico',
                    '.pdf', '.bin', '.gguf', '.db', '.sqlite'}

def get_staged_files():
    result = subprocess.run(
        ['git', 'diff', '--cached', '--name-only', '--diff-filter=ACMR'],
        capture_output=True, text=True
    )
    return [f.strip() for f in result.stdout.splitlines() if f.strip()]

def get_staged_diff(filepath):
    result = subprocess.run(
        ['git', 'diff', '--cached', '-U0', '--', filepath],
        capture_output=True, text=True
    )
    # Only scan added lines (lines starting with '+' but not '+++')
    added = [line[1:] for line in result.stdout.splitlines()
             if line.startswith('+') and not line.startswith('+++')]
    return '\n'.join(added)

def scan_content(content, filepath):
    findings = []
    for pattern, description in SECRET_PATTERNS:
        matches = re.findall(pattern, content, re.IGNORECASE)
        if matches:
            findings.append(f"  ⚠  {description} in {filepath}")
    return findings

def main():
    staged = get_staged_files()
    all_findings = []

    for filepath in staged:
        path = Path(filepath)

        # Skip binary, known-safe, and exempt paths
        if path.suffix in SKIP_EXTENSIONS:
            continue
        if any(filepath.endswith(skip) or skip in filepath for skip in SKIP_PATHS):
            continue

        try:
            diff = get_staged_diff(filepath)
            if diff:
                findings = scan_content(diff, filepath)
                all_findings.extend(findings)
        except Exception:
            pass  # Non-text files — skip silently

    if all_findings:
        print('\n🔴 PRE-COMMIT SECRET SCAN BLOCKED\n')
        print('Potential secrets detected in staged changes:\n')
        for f in all_findings:
            print(f)
        print('\nRemediation:')
        print('  1. Remove the secret from the file.')
        print('  2. Use environment variables or a secrets manager instead.')
        print('  3. If this is a false positive, add the path to SKIP_PATHS in')
        print('     .github/hooks/pre-commit and document why.\n')
        print('To bypass (emergency only):  git commit --no-verify\n')
        sys.exit(1)
    else:
        print('✅ Secret scan: no issues found.')
        sys.exit(0)

if __name__ == '__main__':
    main()
